IMMO_BASE_URL=https://app.immocloud.de
IMMO_EMAIL=your_email@example.com
IMMO_PASSWORD=your_password

# false = visible browser, true = headless
HEADLESS=false

# Persist login between runs
PERSIST_AUTH=true
AUTH_STATE_FILE=.auth/immocloud-storage-state.json

# Optional export params:
# DATEV_EXPORT_START=2026-03-01
# DATEV_EXPORT_END=2026-03-31
# DATEV_EXPORT_RANGE=2026-03-01:2026-03-31
# DATEV_FISCAL_YEAR_START=2026-01-01
# DATEV_OWNER_NAMES=Arona GmbH
# DATEV_PROCESS_FILES=true
# DATEV_KOST1_MAP_FILE=/absolute/path/to/datev-kost1-map.csv
# DOWNLOAD_DIR=downloads

# Optional webhook upload. Sends original CSV files from the DATEV ZIP.
# WEBHOOK_UPLOAD=true
# WEBHOOK_URL=https://example.com/webhook/report-csv-immocloud
# WEBHOOK_TOKEN=optional_bearer_token
# WEBHOOK_FILE_FIELD=files
# WEBHOOK_SOURCE_DIR=downloads/20260423_Datev_20260301-20260331_Arona GmbH
# WEBHOOK_CONVERT_CSV_TO_XLSX=true
# GOOGLE_SHEETS_IMPORT=true
# GOOGLE_OAUTH_CLIENT_ID=your_google_oauth_client_id
# GOOGLE_OAUTH_CLIENT_SECRET=your_google_oauth_client_secret
# GOOGLE_OAUTH_REDIRECT_URI=http://127.0.0.1:3000/oauth2callback
# GOOGLE_OAUTH_TOKEN_FILE=.auth/google-oauth-token.json
# Webhook for Google Drive links. Payload contains links[] and files[].
# GOOGLE_SHEETS_WEBHOOK_URL=https://n8n.srv1309825.hstgr.cloud/webhook/4483f020-c90a-44df-b336-ff286848aee9
# GOOGLE_SHEETS_WEBHOOK_ENABLED=true
# GOOGLE_SHEETS_WEBHOOK_TOKEN=

# Optional Google Drive upload:
# GOOGLE_DRIVE_UPLOAD=true
# GOOGLE_DRIVE_FOLDER_ID=your_drive_folder_id
# GOOGLE_DRIVE_CREDENTIALS_FILE=/absolute/path/to/service-account.json
# or inline json:
# GOOGLE_DRIVE_CREDENTIALS_JSON={"type":"service_account",...}
